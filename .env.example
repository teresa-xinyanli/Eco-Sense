# Environment Variables Template
# Copy this file to .env and fill in your API keys.

# Google Gemini API Key
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap API Key
# Get it from: https://openweathermap.org/api
VITE_OPENWEATHER_KEY=your_openweather_key_here

# PlantNet API Key
# Get it from: https://my.plantnet.org/
VITE_PLANTNET_KEY=your_plantnet_key_here

# Google Maps API Key (Optional, for Street View analysis)
# Get it from: https://console.cloud.google.com/google/maps-apis/credentials
VITE_GOOGLE_MAPS_KEY=your_google_maps_key_here
